GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=change-me
GITHUB_PRIVATE_KEY_PATH=./app-key.pem
COMMENT_MESSAGE=
PORT=8083

# Runner label used when a workflow_run fails due to a rate/usage limit.
SELF_HOSTED_RUNNER_LABEL=self-hosted
# Comma-separated, case-insensitive substrings matched against failed jobs'
# names/annotations to decide a failure was rate-limit related. Leave unset
# to use the built-in default list.
RATE_LIMIT_KEYWORDS="rate limit", "concurrency limit", "spending limit" 
# Comma-separated workflow_run conclusions that trigger the rate-limit check.
TRIGGER_CONCLUSIONS=failure,startup_failure
# Where to persist which repos/workflows were switched to self-hosted, so
# the monthly (1st of month) job knows what to revert to ubuntu-latest.
STATE_FILE_PATH=./state.json
